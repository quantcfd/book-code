# ==============================================================================
# QuantCFD - .gitignore
# ==============================================================================

# ---- Data files (do not commit market data) ----
*.csv
*.parquet
*.h5
*.hdf5
*.xlsx
*.xls
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ---- Output / results ----
results/
*.png
*.jpg
*.jpeg
*.pdf
!docs/**/*.png
!docs/**/*.jpg

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/
.conda/

# ---- Jupyter ----
.ipynb_checkpoints/
*.ipynb_checkpoints
.jupyter/

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ---- Secrets / credentials ----
.env
.env.local
*.key
*.pem
credentials.json
api_keys.txt
config_secret.py

# ---- Tests / coverage ----
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
